generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// IDENTITY & MULTI-TENANT
// ============================================================

model Tenant {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  brandConfig     Json?
  plan            String   @default("starter")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users           User[]
  businesses      Business[]
  ledgerEvents    LedgerEvent[]
  consentRecords  ConsentRecord[]
  complianceChecks ComplianceCheck[]
  documents       Document[]

  @@map("tenants")
}

model User {
  id              String   @id @default(uuid())
  tenantId        String
  email           String
  passwordHash    String?
  firstName       String
  lastName        String
  role            String   @default("advisor")
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String?
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  auditLogs       AuditLog[]
  advisorDeals    Business[] @relation("AdvisorBusinesses")

  @@unique([tenantId, email])
  @@map("users")
}

model AuditLog {
  id              String   @id @default(uuid())
  userId          String?
  tenantId        String
  action          String
  resource        String
  resourceId      String?
  metadata        Json?
  ipAddress       String?
  timestamp       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, timestamp])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// ============================================================
// BUSINESS & ONBOARDING
// ============================================================

model Business {
  id                  String   @id @default(uuid())
  tenantId            String
  advisorId           String?
  legalName           String
  dba                 String?
  ein                 String?
  entityType          String
  stateOfFormation    String?
  dateOfFormation     DateTime?
  mcc                 String?
  industry            String?
  annualRevenue       Decimal?
  monthlyRevenue      Decimal?
  fundingReadinessScore Int?
  status              String   @default("intake")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  advisor             User?    @relation("AdvisorBusinesses", fields: [advisorId], references: [id])
  owners              BusinessOwner[]
  creditProfiles      CreditProfile[]
  fundingRounds       FundingRound[]
  cardApplications    CardApplication[]
  complianceChecks    ComplianceCheck[]
  consentRecords      ConsentRecord[]
  documents           Document[]
  suitabilityChecks   SuitabilityCheck[]
  acknowledgments     ProductAcknowledgment[]
  achAuthorizations   AchAuthorization[]
  costCalculations    CostCalculation[]

  @@index([tenantId, status])
  @@map("businesses")
}

model BusinessOwner {
  id                  String   @id @default(uuid())
  businessId          String
  firstName           String
  lastName            String
  ownershipPercent    Decimal
  ssn                 String?
  dateOfBirth         DateTime?
  address             Json?
  isBeneficialOwner   Boolean  @default(true)
  kycStatus           String   @default("pending")
  kycVerifiedAt       DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business            Business @relation(fields: [businessId], references: [id])

  @@map("business_owners")
}

// ============================================================
// CREDIT & INTELLIGENCE
// ============================================================

model CreditProfile {
  id                  String   @id @default(uuid())
  businessId          String
  profileType         String   // personal | business
  bureau              String   // equifax | transunion | experian | dnb
  score               Int?
  scoreType           String?  // fico | vantage | sbss | paydex
  utilization         Decimal?
  inquiryCount        Int?
  derogatoryCount     Int?
  tradelines          Json?
  rawData             Json?
  pulledAt            DateTime
  createdAt           DateTime @default(now())

  business            Business @relation(fields: [businessId], references: [id])

  @@index([businessId, bureau, pulledAt])
  @@map("credit_profiles")
}

// ============================================================
// FUNDING & APPLICATIONS
// ============================================================

model FundingRound {
  id                  String   @id @default(uuid())
  businessId          String
  roundNumber         Int
  targetCredit        Decimal?
  targetCardCount     Int?
  status              String   @default("planning")
  aprExpiryDate       DateTime?
  alertSent60         Boolean  @default(false)
  alertSent30         Boolean  @default(false)
  alertSent15         Boolean  @default(false)
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business            Business @relation(fields: [businessId], references: [id])
  applications        CardApplication[]

  @@unique([businessId, roundNumber])
  @@map("funding_rounds")
}

model CardApplication {
  id                  String   @id @default(uuid())
  businessId          String
  fundingRoundId      String?
  issuer              String
  cardProduct         String
  status              String   @default("draft")
  creditLimit         Decimal?
  introApr            Decimal?
  introAprExpiry      DateTime?
  regularApr          Decimal?
  annualFee           Decimal?
  cashAdvanceFee      Decimal?
  consentCapturedAt   DateTime?
  submittedAt         DateTime?
  decidedAt           DateTime?
  declineReason       String?
  adverseActionNotice Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business            Business @relation(fields: [businessId], references: [id])
  fundingRound        FundingRound? @relation(fields: [fundingRoundId], references: [id])

  @@index([businessId, status])
  @@map("card_applications")
}

model SuitabilityCheck {
  id                  String   @id @default(uuid())
  businessId          String
  score               Int
  maxSafeLeverage     Decimal?
  recommendation      String
  noGoTriggered       Boolean  @default(false)
  noGoReasons         Json?
  alternativeProducts Json?
  decisionExplanation String?
  overriddenBy        String?
  overrideReason      String?
  createdAt           DateTime @default(now())

  business            Business @relation(fields: [businessId], references: [id])

  @@map("suitability_checks")
}

// ============================================================
// CONSENT & COMPLIANCE
// ============================================================

model ConsentRecord {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String?
  channel             String   // voice | sms | email | partner | document
  consentType         String   // tcpa | data_sharing | referral | application
  status              String   @default("active") // active | revoked | expired
  grantedAt           DateTime @default(now())
  revokedAt           DateTime?
  revocationReason    String?
  ipAddress           String?
  evidenceRef         String?
  metadata            Json?

  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  business            Business? @relation(fields: [businessId], references: [id])

  @@index([tenantId, businessId, channel])
  @@index([status])
  @@map("consent_records")
}

model ProductAcknowledgment {
  id                  String   @id @default(uuid())
  businessId          String
  acknowledgmentType  String   // product_reality | fee_schedule | personal_guarantee | cash_advance_risk
  version             String
  signedAt            DateTime
  signatureRef        String?
  documentVaultId     String?
  metadata            Json?
  createdAt           DateTime @default(now())

  business            Business @relation(fields: [businessId], references: [id])

  @@map("product_acknowledgments")
}

model ComplianceCheck {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String?
  checkType           String   // udap | state_law | vendor | kyb
  riskScore           Int?
  riskLevel           String?  // low | medium | high | critical
  findings            Json?
  stateJurisdiction   String?
  resolvedAt          DateTime?
  createdAt           DateTime @default(now())

  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  business            Business? @relation(fields: [businessId], references: [id])

  @@index([tenantId, checkType])
  @@map("compliance_checks")
}

// ============================================================
// ACH & DEBIT CONTROLS
// ============================================================

model AchAuthorization {
  id                  String   @id @default(uuid())
  businessId          String
  processorName       String
  authorizedAmount    Decimal?
  authorizedFrequency String?
  status              String   @default("active") // active | revoked | suspended
  signedDocumentRef   String?
  authorizedAt        DateTime
  revokedAt           DateTime?
  revocationNotifiedAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business            Business @relation(fields: [businessId], references: [id])
  debitEvents         DebitEvent[]

  @@map("ach_authorizations")
}

model DebitEvent {
  id                  String   @id @default(uuid())
  authorizationId     String
  amount              Decimal
  frequency           String?
  isWithinTolerance   Boolean  @default(true)
  flagged             Boolean  @default(false)
  flagReason          String?
  processedAt         DateTime
  createdAt           DateTime @default(now())

  authorization       AchAuthorization @relation(fields: [authorizationId], references: [id])

  @@map("debit_events")
}

// ============================================================
// FINANCIAL
// ============================================================

model CostCalculation {
  id                  String   @id @default(uuid())
  businessId          String
  programFees         Decimal  @default(0)
  percentOfFunding    Decimal  @default(0)
  annualFees          Decimal  @default(0)
  cashAdvanceFees     Decimal  @default(0)
  processorFees       Decimal  @default(0)
  totalCost           Decimal  @default(0)
  effectiveApr        Decimal?
  irc163jImpact       Decimal?
  bestCaseFlow        Json?
  baseCaseFlow        Json?
  worstCaseFlow       Json?
  createdAt           DateTime @default(now())

  business            Business @relation(fields: [businessId], references: [id])

  @@map("cost_calculations")
}

// ============================================================
// CANONICAL LEDGER & EVENT BUS
// ============================================================

model LedgerEvent {
  id                  String   @id @default(uuid())
  tenantId            String
  eventType           String
  aggregateType       String
  aggregateId         String
  payload             Json
  metadata            Json?
  version             Int      @default(1)
  publishedAt         DateTime @default(now())
  processedAt         DateTime?

  tenant              Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, eventType])
  @@index([aggregateType, aggregateId])
  @@index([publishedAt])
  @@map("ledger_events")
}

// ============================================================
// DOCUMENT VAULT
// ============================================================

model Document {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String?
  documentType        String
  title               String
  storageKey          String
  mimeType            String?
  sizeBytes           Int?
  sha256Hash          String?
  cryptoTimestamp      String?
  legalHold           Boolean  @default(false)
  metadata            Json?
  uploadedBy          String?
  createdAt           DateTime @default(now())

  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  business            Business? @relation(fields: [businessId], references: [id])

  @@index([tenantId, documentType])
  @@index([businessId])
  @@map("documents")
}

// ============================================================
// DECLINE RECOVERY & ADVERSE ACTION
// ============================================================

model DeclineRecovery {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  applicationId       String
  issuer              String
  declineReasons      Json
  adverseActionRaw    String?
  reconsiderationStatus String @default("pending")
  reconsiderationNotes String?
  reapplyCooldownDate DateTime?
  letterGenerated     Boolean  @default(false)
  recoveryStage       String   @default("new")
  resolvedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, businessId])
  @@map("decline_recoveries")
}

// ============================================================
// REPAYMENT & TREASURY
// ============================================================

model RepaymentPlan {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  totalBalance        Decimal
  monthlyPayment      Decimal?
  strategy            String   @default("avalanche")
  status              String   @default("active")
  interestShockDate   DateTime?
  interestShockAmount Decimal?
  nextPaymentDate     DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  schedules           PaymentSchedule[]

  @@index([tenantId, businessId])
  @@map("repayment_plans")
}

model PaymentSchedule {
  id                  String   @id @default(uuid())
  repaymentPlanId     String
  cardApplicationId   String?
  issuer              String
  dueDate             DateTime
  minimumPayment      Decimal
  recommendedPayment  Decimal?
  actualPayment       Decimal?
  status              String   @default("upcoming")
  autopayEnabled      Boolean  @default(false)
  autopayVerified     Boolean  @default(false)
  paidAt              DateTime?
  createdAt           DateTime @default(now())

  repaymentPlan       RepaymentPlan @relation(fields: [repaymentPlanId], references: [id])

  @@index([repaymentPlanId, dueDate])
  @@map("payment_schedules")
}

// ============================================================
// SPEND GOVERNANCE & BUSINESS PURPOSE
// ============================================================

model SpendTransaction {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  cardApplicationId   String?
  amount              Decimal
  merchantName        String?
  mcc                 String?
  mccCategory         String?
  riskScore           Int?
  isCashLike          Boolean  @default(false)
  businessPurpose     String?
  evidenceDocId       String?
  flagged             Boolean  @default(false)
  flagReason          String?
  transactionDate     DateTime
  createdAt           DateTime @default(now())

  @@index([tenantId, businessId])
  @@index([mcc])
  @@map("spend_transactions")
}

// ============================================================
// REWARDS & CARD BENEFITS
// ============================================================

model RewardsOptimization {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  cardApplicationId   String
  mccCategory         String
  rewardsRate         Decimal
  annualValue         Decimal?
  isOptimalCard       Boolean  @default(false)
  createdAt           DateTime @default(now())

  @@index([tenantId, businessId])
  @@map("rewards_optimizations")
}

model CardBenefit {
  id                  String   @id @default(uuid())
  cardApplicationId   String
  benefitType         String
  benefitName         String
  benefitValue        Decimal?
  expiryDate          DateTime?
  utilized            Boolean  @default(false)
  utilizedDate        DateTime?
  createdAt           DateTime @default(now())

  @@map("card_benefits")
}

// ============================================================
// REVENUE OPS & BILLING
// ============================================================

model Invoice {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  invoiceNumber       String
  type                String
  amount              Decimal
  feeBreakdown        Json?
  status              String   @default("draft")
  issuedAt            DateTime?
  dueDate             DateTime?
  paidAt              DateTime?
  stripePaymentId     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, businessId])
  @@map("invoices")
}

model CommissionRecord {
  id                  String   @id @default(uuid())
  tenantId            String
  invoiceId           String?
  partnerId           String?
  advisorId           String?
  amount              Decimal
  percentage          Decimal?
  type                String
  status              String   @default("pending")
  paidAt              DateTime?
  createdAt           DateTime @default(now())

  @@index([tenantId])
  @@map("commission_records")
}

// ============================================================
// STATEMENT RECONCILIATION
// ============================================================

model StatementRecord {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  cardApplicationId   String?
  issuer              String
  statementDate       DateTime
  closingBalance      Decimal?
  minimumPayment      Decimal?
  dueDate             DateTime?
  interestCharged     Decimal?
  feesCharged         Decimal?
  sourceDocumentId    String?
  normalizedData      Json?
  anomalies           Json?
  reconciled          Boolean  @default(false)
  createdAt           DateTime @default(now())

  @@index([tenantId, businessId])
  @@map("statement_records")
}

// ============================================================
// DEAL COMMITTEE
// ============================================================

model DealCommitteeReview {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  riskTier            String
  status              String   @default("pending")
  redFlagChecklist    Json?
  committeeNotes      String?
  conditions          Json?
  counselSignoff      Boolean  @default(false)
  accountantSignoff   Boolean  @default(false)
  reviewedBy          Json?
  decidedAt           DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, status])
  @@map("deal_committee_reviews")
}

// ============================================================
// HARDSHIP & WORKOUT
// ============================================================

model HardshipCase {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  triggerType         String
  severity            String
  status              String   @default("open")
  paymentPlan         Json?
  settlementOffer     Json?
  counselorReferral   String?
  cardClosureSequence Json?
  resolvedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, status])
  @@map("hardship_cases")
}

// ============================================================
// COMPLAINTS & REMEDIATION
// ============================================================

model Complaint {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String?
  category            String
  subcategory         String?
  source              String
  severity            String   @default("medium")
  status              String   @default("open")
  description         String
  evidenceDocIds      Json?
  callRecordIds       Json?
  rootCause           String?
  resolution          String?
  assignedTo          String?
  escalatedTo         String?
  resolvedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, status])
  @@index([category])
  @@map("complaints")
}

// ============================================================
// PARTNER & VENDOR GOVERNANCE
// ============================================================

model Partner {
  id                  String   @id @default(uuid())
  tenantId            String
  name                String
  type                String
  status              String   @default("active")
  complianceScore     Int?
  dueDiligenceStatus  String   @default("pending")
  contractId          String?
  onboardedAt         DateTime?
  nextReviewDate      DateTime?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  referralAttributions ReferralAttribution[]

  @@index([tenantId, type])
  @@map("partners")
}

// ============================================================
// CONTRACT INTELLIGENCE
// ============================================================

model ContractAnalysis {
  id                  String   @id @default(uuid())
  tenantId            String
  partnerId           String?
  documentId          String?
  contractType        String
  extractedClauses    Json?
  redFlags            Json?
  missingProtections  Json?
  riskScore           Int?
  analyzedAt          DateTime @default(now())
  createdAt           DateTime @default(now())

  @@index([tenantId])
  @@map("contract_analyses")
}

// ============================================================
// COMMUNICATION COMPLIANCE
// ============================================================

model CommComplianceRecord {
  id                  String   @id @default(uuid())
  tenantId            String
  advisorId           String
  channel             String
  content             String?
  violations          Json?
  riskScore           Int?
  approved            Boolean?
  reviewedAt          DateTime?
  createdAt           DateTime @default(now())

  @@index([tenantId, advisorId])
  @@map("comm_compliance_records")
}

model ApprovedScript {
  id                  String   @id @default(uuid())
  tenantId            String
  name                String
  category            String
  content             String
  version             String
  isActive            Boolean  @default(true)
  approvedBy          String?
  approvedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, category])
  @@map("approved_scripts")
}

// ============================================================
// TRAINING & CERTIFICATION
// ============================================================

model TrainingCertification {
  id                  String   @id @default(uuid())
  tenantId            String
  userId              String
  trackName           String
  status              String   @default("not_started")
  score               Int?
  completedAt         DateTime?
  expiresAt           DateTime?
  certificateRef      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, userId])
  @@map("training_certifications")
}

// ============================================================
// DISCLOSURE & TEMPLATE CMS
// ============================================================

model DisclosureTemplate {
  id                  String   @id @default(uuid())
  tenantId            String
  state               String
  category            String
  name                String
  content             String
  version             String
  effectiveDate       DateTime
  isActive            Boolean  @default(true)
  approvedBy          String?
  approvedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, state, category])
  @@map("disclosure_templates")
}

// ============================================================
// WORKFLOW AUTOMATION & POLICY
// ============================================================

model WorkflowRule {
  id                  String   @id @default(uuid())
  tenantId            String
  name                String
  conditions          Json
  actions             Json
  priority            Int      @default(0)
  isActive            Boolean  @default(true)
  triggerEvent        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, isActive])
  @@map("workflow_rules")
}

model PolicyRule {
  id                  String   @id @default(uuid())
  tenantId            String
  name                String
  ruleType            String
  conditions          Json
  actions             Json
  stopOnMatch         Boolean  @default(false)
  version             String
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, ruleType])
  @@map("policy_rules")
}

// ============================================================
// REFERRAL & AFFILIATE
// ============================================================

model ReferralAttribution {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  sourceType          String
  sourceId            String?
  partnerId           String?
  channel             String?
  feeAmount           Decimal?
  feeStatus           String   @default("pending")
  consentDocId        String?
  paidAt              DateTime?
  createdAt           DateTime @default(now())

  partner             Partner? @relation(fields: [partnerId], references: [id])

  @@index([tenantId, businessId])
  @@map("referral_attributions")
}

// ============================================================
// REGULATORY INTELLIGENCE
// ============================================================

model RegulatoryAlert {
  id                  String   @id @default(uuid())
  tenantId            String
  source              String
  ruleType            String
  title               String
  summary             String
  impactScore         Int?
  affectedModules     Json?
  status              String   @default("new")
  reviewedBy          String?
  reviewedAt          DateTime?
  effectiveDate       DateTime?
  createdAt           DateTime @default(now())

  @@index([tenantId, status])
  @@map("regulatory_alerts")
}

// ============================================================
// CRM & ANALYTICS
// ============================================================

model PipelineStage {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  stage               String
  enteredAt           DateTime @default(now())
  exitedAt            DateTime?
  advisorId           String?
  notes               String?

  @@index([tenantId, stage])
  @@map("pipeline_stages")
}

model AdvisorQaScore {
  id                  String   @id @default(uuid())
  tenantId            String
  advisorId           String
  callRecordId        String?
  overallScore        Int
  complianceScore     Int?
  scriptAdherence     Int?
  consentCapture      Int?
  riskClaimAvoidance  Int?
  feedback            String?
  scoredAt            DateTime @default(now())

  @@index([tenantId, advisorId])
  @@map("advisor_qa_scores")
}

// ============================================================
// MULTI-TENANT SAAS
// ============================================================

model TenantPlan {
  id                  String   @id @default(uuid())
  tenantId            String
  planName            String
  moduleEntitlements  Json
  usageLimits         Json?
  monthlyPrice        Decimal?
  billingCycle        String   @default("monthly")
  startDate           DateTime
  endDate             DateTime?
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId])
  @@map("tenant_plans")
}

model UsageMeter {
  id                  String   @id @default(uuid())
  tenantId            String
  metricName          String
  metricValue         Int      @default(0)
  periodStart         DateTime
  periodEnd           DateTime
  createdAt           DateTime @default(now())

  @@index([tenantId, metricName, periodStart])
  @@map("usage_meters")
}

// ============================================================
// ISSUER RELATIONSHIP MGMT
// ============================================================

model IssuerContact {
  id                  String   @id @default(uuid())
  tenantId            String
  issuer              String
  contactName         String?
  contactRole         String?
  phone               String?
  email               String?
  reconsiderationLine String?
  notes               String?
  relationshipScore   Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, issuer])
  @@map("issuer_contacts")
}

// ============================================================
// SECTION 1071 / FAIR LENDING
// ============================================================

model FairLendingRecord {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String
  applicationId       String?
  demographicData     Json?
  businessType        String?
  creditPurpose       String?
  actionTaken         String?
  actionDate          DateTime?
  adverseReasons      Json?
  isFirewalled        Boolean  @default(true)
  createdAt           DateTime @default(now())

  @@index([tenantId])
  @@map("fair_lending_records")
}

// ============================================================
// FUNDS-FLOW CLASSIFICATION
// ============================================================

model FundsFlowClassification {
  id                  String   @id @default(uuid())
  tenantId            String
  workflowName        String
  classification      String
  riskBasis           String?
  regulatoryFramework String?
  legalOpinionRef     String?
  status              String   @default("active")
  reviewedBy          String?
  reviewedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, classification])
  @@map("funds_flow_classifications")
}

// ============================================================
// OFFBOARDING & DATA DELETION
// ============================================================

model OffboardingWorkflow {
  id                  String   @id @default(uuid())
  tenantId            String
  businessId          String?
  offboardingType     String
  status              String   @default("initiated")
  finalInvoiceId      String?
  refundAmount        Decimal?
  dataExportCompleted Boolean  @default(false)
  dataDeletionStatus  String   @default("pending")
  deletionProofHash   String?
  retentionSchedule   Json?
  exitReason          String?
  exitInterviewNotes  String?
  initiatedAt         DateTime @default(now())
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, status])
  @@map("offboarding_workflows")
}

// ============================================================
// AI GOVERNANCE
// ============================================================

model AiDecisionLog {
  id                  String   @id @default(uuid())
  tenantId            String
  moduleSource        String
  decisionType        String
  inputHash           String?
  output              Json
  confidence          Decimal?
  overriddenBy        String?
  overrideReason      String?
  modelVersion        String?
  promptVersion       String?
  latencyMs           Int?
  createdAt           DateTime @default(now())

  @@index([tenantId, moduleSource])
  @@map("ai_decision_logs")
}

// ============================================================
// SANDBOX & SIMULATION
// ============================================================

model SandboxProfile {
  id                  String   @id @default(uuid())
  tenantId            String
  profileName         String
  archetype           String
  profileData         Json
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  @@index([tenantId])
  @@map("sandbox_profiles")
}

// ============================================================
// BUSINESS CONTINUITY
// ============================================================

model BackupRecord {
  id                  String   @id @default(uuid())
  tenantId            String?
  backupType          String
  status              String   @default("completed")
  sizeBytes           Int?
  storageLocation     String?
  retentionDays       Int      @default(90)
  expiresAt           DateTime?
  createdAt           DateTime @default(now())

  @@index([backupType, createdAt])
  @@map("backup_records")
}
