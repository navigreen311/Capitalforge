# CapitalForge Environment Variables
# Copy this to .env and fill in real values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/capitalforge
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN_HERE
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID_HERE
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET_HERE

# AI / Claude API
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Integrations
PLAID_CLIENT_ID=YOUR_PLAID_CLIENT_ID_HERE
PLAID_SECRET=YOUR_PLAID_SECRET_HERE
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_HERE
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUB_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
STRIPE_PRICE_STARTER=price_starter_297
STRIPE_PRICE_PRO=price_pro_697
DOCUSIGN_INTEGRATION_KEY=YOUR_DOCUSIGN_KEY_HERE
DOCUSIGN_SECRET_KEY=YOUR_DOCUSIGN_SECRET_HERE
DOCUSIGN_ACCOUNT_ID=YOUR_DOCUSIGN_ACCOUNT_HERE
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_USER_ID=YOUR_DOCUSIGN_USER_ID_HERE
DOCUSIGN_PRIVATE_KEY=YOUR_DOCUSIGN_PRIVATE_KEY_HERE
DOCUSIGN_WEBHOOK_HMAC_SECRET=YOUR_DOCUSIGN_HMAC_SECRET_HERE
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN_HERE

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_HERE
S3_BUCKET_NAME=capitalforge-documents

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
