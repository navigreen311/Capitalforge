{
  "expo": {
    "name": "CapitalForge",
    "slug": "capitalforge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "primaryColor": "#C9A84C",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.capitalforge.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "CapitalForge needs camera access to capture KYB documents and receipts.",
        "NSFaceIDUsageDescription": "CapitalForge uses Face ID to protect your account.",
        "NSPhotoLibraryUsageDescription": "CapitalForge needs access to your photo library to upload documents."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "package": "com.capitalforge.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "CapitalForge needs camera access to capture KYB documents and receipts."
        }
      ],
      "expo-secure-store",
      "expo-local-authentication"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:3000/api/v1"
    }
  }
}
